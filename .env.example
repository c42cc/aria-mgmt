# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=
DISCORD_TEXT_CHANNEL_ID=
DISCORD_LOG_CHANNEL_ID=
AUTHORIZED_USER_IDS=

# Google (Gemini)
GOOGLE_API_KEY=

# Anthropic (Claude Opus 4.6)
ANTHROPIC_API_KEY=

# Cursor
CURSOR_API_KEY=

# Gmail MCP (OAuth credentials in ~/.gmail-mcp/gcp-oauth.keys.json)
# Uses same GCP project as google-calendar. Add Gmail API scope.
# First run: npx @gongrzhe/server-gmail-autoauth-mcp (opens browser for OAuth consent)

# Anchor pressure-test thresholds (used by deploy gate)
ANCHOR_GATE_ENABLED=false
ANCHOR_AGREEMENT_THRESHOLD=0.90
ANCHOR_HALLUCINATION_MAX=0.05
ANCHOR_COVERAGE_THRESHOLD=0.80

# Cost guardrails
DAILY_SPEND_CAP_USD=20
PER_SESSION_CLAUDE_CALLS_MAX=15
PER_SESSION_CURSOR_RUNS_MAX=5

# Behavior knobs
GEMINI_MODEL=gemini-3.1-flash-live-preview
CLAUDE_MODEL=claude-opus-4-6
CURSOR_MODEL=composer-2

# External Cursor observer (watches other Cursor IDE windows on this Mac
# via ~/.cursor/hooks.json). The bot runs a small aiohttp server on this
# host:port; the hook forwarder POSTs lifecycle events to it.
# Install hooks once: .venv/bin/python hooks/install.py
UCS_CURSOR_EVENT_HOST=127.0.0.1
UCS_CURSOR_EVENT_PORT=8731
UCS_CURSOR_DM_PAGER_ENABLED=true

# ModelVault — cold-backup vault (standalone CLI; not used by the bot).
# Run `bash ops/modelvault_provision.sh` (GCS) or `--local DIR` (offline target);
# it generates the crypt key and prints exactly which of these to set here.
# MODELVAULT_RCLONE_CONF points at the mode-600 rclone.conf that holds the crypt
# secret — the crown jewel. Never commit it; keep an offline backup.
MODELVAULT_RCLONE_CONF=
# Only needed if you encrypt rclone.conf itself at rest (rclone config encryption):
RCLONE_CONFIG_PASS=
# Set by the GCS provisioning run (the tool itself only addresses rclone remotes):
MODELVAULT_GCP_PROJECT=
MODELVAULT_BUCKET=
MODELVAULT_SA_KEY_FILE=
# Optional: HF token for gated/private repos; small temp dir for config/headers.
HF_TOKEN=
MODELVAULT_TMP_DIR=
