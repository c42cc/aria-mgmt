# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=
DISCORD_TEXT_CHANNEL_ID=
DISCORD_LOG_CHANNEL_ID=
AUTHORIZED_USER_IDS=

# Google (Gemini)
GOOGLE_API_KEY=

# Anthropic (Claude Opus 4.6)
ANTHROPIC_API_KEY=

# Cursor
CURSOR_API_KEY=

# Gmail MCP (OAuth credentials in ~/.gmail-mcp/gcp-oauth.keys.json)
# Uses same GCP project as google-calendar. Add Gmail API scope.
# First run: npx @gongrzhe/server-gmail-autoauth-mcp (opens browser for OAuth consent)

# Anchor pressure-test thresholds (used by deploy gate)
ANCHOR_GATE_ENABLED=false
ANCHOR_AGREEMENT_THRESHOLD=0.90
ANCHOR_HALLUCINATION_MAX=0.05
ANCHOR_COVERAGE_THRESHOLD=0.80

# Cost guardrails
DAILY_SPEND_CAP_USD=20
PER_SESSION_CLAUDE_CALLS_MAX=15
PER_SESSION_CURSOR_RUNS_MAX=5

# Behavior knobs
GEMINI_MODEL=gemini-3.1-flash-live-preview
CLAUDE_MODEL=claude-opus-4-6
CURSOR_MODEL=composer-2

# Local Spark Agent — a local-brained chat window over the same agent loop.
# ANTHROPIC_BASE_URL points the Anthropic SDK (the agent loop's brain) at the
# DGX Spark's vLLM, which serves /v1/messages natively. Leave EMPTY for the main
# bot (cloud Opus). The local chat process sets it to the Spark endpoint and
# sets CLAUDE_MODEL to the served-model-name ('local-brain'). `make local-chat`
# resolves spark1's endpoint for you. Verify the brain: scripts/spark_serve.py.
# ANTHROPIC_BASE_URL=http://100.106.152.104:8000
LOCAL_CHAT_HOST=127.0.0.1
LOCAL_CHAT_PORT=8742
# Required to bind the chat to a non-loopback host (reach it from your phone over
# Tailscale). Any strong string; the browser sends it back. Empty = loopback only.
LOCAL_CHAT_SECRET=

# Web search MCP ("do search for me"). Set ONE to enable; Brave is the default.
# Without either, search is simply off (the bot still reads notes/files/mail).
BRAVE_API_KEY=
TAVILY_API_KEY=

# External Cursor observer (watches other Cursor IDE windows on this Mac
# via ~/.cursor/hooks.json). The bot runs a small aiohttp server on this
# host:port; the hook forwarder POSTs lifecycle events to it.
# Install hooks once: .venv/bin/python hooks/install.py
UCS_CURSOR_EVENT_HOST=127.0.0.1
UCS_CURSOR_EVENT_PORT=8731
