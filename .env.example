# Aria v2 — copy to .env and fill in. Only ANTHROPIC_API_KEY is required for the
# text spine; everything else is optional or for later phases.

# Required — the conductor (Claude) and the engine (Claude Code) both use this.
ANTHROPIC_API_KEY=

# Optional — the Gemini/voice layer (Phase 1) and any Gemini use.
GEMINI_API_KEY=

# Models — verified-live defaults are baked into src/config.py; override ONLY
# with current ids (a retired id is a hard error).
# ARIA_REASONING_MODEL=claude-opus-4-8
# ARIA_FAST_MODEL=claude-haiku-4-5
# ARIA_VOICE_MODEL=gemini-3.1-flash-live-preview

# Conductor tiering: routine/interview turns on the fast model, report on Opus.
# ARIA_CONDUCTOR_TIER=true

# Engine billing: 'subscription' (your Claude subscription) or 'api' (pay-as-you-go).
# ARIA_CLAUDE_CODE_BILLING=subscription
# ARIA_CC_MAX_BUDGET_USD=5

# Guardrails.
# DAILY_SPEND_CAP_USD=20

# Voice (Phase 1) — create a LiveKit Cloud project; see docs/aria-v2/phase1-voice.md
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# The house (Phase 4) — Home Assistant endpoint. Point at your HA instance
# (local-first, e.g. over Tailscale) and a long-lived access token; expose only
# the entities Aria should touch (HA: Settings > Voice assistants > Expose).
# Unset = the house endpoint reports "not configured" (no silent fallback).
# See docs/aria-v2/phase4-house.md.
# HASS_URL=http://homeassistant.local:8123
# HASS_TOKEN=

# Spark endpoint — a local open-source model served on the DGX Spark (vLLM serves
# the Anthropic Messages API natively). Loops with endpoint `spark` run here.
# SPARK_BASE_URL=http://spark1:8000
# SPARK_MODEL=local-brain
