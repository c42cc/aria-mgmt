<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.you.voicebot</string>

    <!-- Launch through ops/launch.sh: it pins the running process to the trunk
         (git checkout main) before the editable reinstall + exec, so KeepAlive
         can never again boot a drifted feature branch (the original incident).
         launch.sh does NOT pkill (a `pkill -f src.bot` under KeepAlive can kill
         its own launching shell and crash-loop) and `exec`s python, so launchd
         supervises the bot process directly. -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/corbin/PycharmProjects/agi_env_v1/ucs2/ops/launch.sh</string>
    </array>

    <!-- CWD = repo root so dotenv finds .env (secrets stay in .env, not here). -->
    <key>WorkingDirectory</key>
    <string>/Users/corbin/PycharmProjects/agi_env_v1/ucs2</string>

    <!-- launchd hands a minimal PATH. Aria spawns node (voice sidecar), npx (MCP
         fleet), ffmpeg, screencapture (/usr/sbin), osascript (/usr/bin). The old
         PATH here omitted /usr/sbin and the Homebrew sbin dirs, so screencapture
         was "command not found" under the service. This is the same contracted
         PATH the in-process capability layer guarantees. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/local/sbin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
    </dict>

    <!-- Always-live: start at login, restart on any exit, throttled to >=15s. -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>15</integer>

    <!-- Real-time voice wants responsive scheduling, not background throttling. -->
    <key>ProcessType</key>
    <string>Interactive</string>

    <key>StandardOutPath</key>
    <string>/Users/corbin/Library/Logs/voicebot/stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/corbin/Library/Logs/voicebot/stderr.log</string>
</dict>
</plist>
