#!/usr/bin/env bash
# Aria control. All commands assume the plist is installed at
# ~/Library/LaunchAgents/com.you.voicebot.plist.

set -euo pipefail
LABEL="com.you.voicebot"
UID_GUI="gui/$(id -u)"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
REPO="/Users/corbin/PycharmProjects/agi_env_v1/ucs2"
LOG_DIR="$HOME/Library/Logs/voicebot"

case "${1:-status}" in
  start)         launchctl bootstrap "$UID_GUI" "$PLIST" 2>/dev/null \
                 && echo "Aria: starting" \
                 || echo "Aria: already loaded (use 'restart' to relaunch)";;
  stop|sleep)    launchctl bootout "$UID_GUI/$LABEL" \
                 && echo "Aria: stopped (will not auto-restart, even on reboot)";;
  restart)       launchctl kickstart -k "$UID_GUI/$LABEL" \
                 && echo "Aria: restarting in place";;
  status)        launchctl print "$UID_GUI/$LABEL" 2>/dev/null \
                 | grep -E 'state|pid|runs|last exit' || echo "Aria: not loaded";;
  logs)          tail -f "$LOG_DIR/stderr.log";;
  update)        cd "$REPO" && git pull --ff-only && launchctl kickstart -k "$UID_GUI/$LABEL";;
  reload-plist)  launchctl bootout "$UID_GUI/$LABEL" 2>/dev/null || true
                 launchctl bootstrap "$UID_GUI" "$PLIST";;
  *) echo "usage: aria {start|sleep|restart|status|logs|update|reload-plist}"; exit 1;;
esac
